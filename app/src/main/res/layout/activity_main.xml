<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backcolor">

    <!-- ================= zones ================= -->

    <androidx.constraintlayout.widget.Guideline
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/g_header"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.3"/>

    <androidx.constraintlayout.widget.Guideline
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/g_rooms"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.85"/>


    <!-- ================= header ================= -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/g_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <ImageView
            android:id="@+id/home_shape"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/homeshape"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/user_head"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/user_head"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/houseName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:autoSizeTextType="uniform"
            android:textSize="22sp"
            android:textColor="@color/black"
            app:layout_constraintTop_toBottomOf="@id/user_head"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ================= rooms container ================= -->

    <!-- ================= bottom nav ================= -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rooms_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/g_rooms"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/g_header"
        app:layout_constraintVertical_bias="1.0">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/help1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.20" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/help2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.8" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/help3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.1" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/help4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.9" />
        <androidx.constraintlayout.widget.Guideline
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/g_text"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.1"/>

        <TextView
            android:id="@+id/title_rooms"
            android:layout_width="0dp"
            android:layout_height="67dp"
            android:autoSizeTextType="uniform"
            android:background="@drawable/textofbedrooms"
            android:gravity="center"
            android:text="choose the room you want to manage"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="18sp"
            app:layout_constraintEnd_toStartOf="@+id/help4"
            app:layout_constraintStart_toStartOf="@+id/help3"
            app:layout_constraintTop_toTopOf="@+id/g_text" />

        <!-- bedroom block -->

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bedroom_block"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/kitchen_block"
            app:layout_constraintEnd_toStartOf="@+id/help4"
            app:layout_constraintStart_toStartOf="@+id/help3"
            app:layout_constraintTop_toBottomOf="@id/title_rooms">

            <ImageView
                android:id="@+id/ic_bedroom"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bedroom"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/bedroom_btn"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginEnd="16dp"
                android:autoSizeTextType="uniform"
                android:background="@drawable/roomsbutton"
                android:text="bedrooms"
                android:textColor="@color/black"
                android:textSize="18sp"
                app:backgroundTint="@null"
                app:layout_constraintBottom_toBottomOf="@id/ic_bedroom"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ic_bedroom"
                app:layout_constraintTop_toTopOf="@id/ic_bedroom" />

            <androidx.constraintlayout.widget.Guideline
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- kitchen block -->

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/kitchen_block"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/bathroom_block"
            app:layout_constraintEnd_toStartOf="@+id/help4"
            app:layout_constraintStart_toStartOf="@+id/help3"
            app:layout_constraintTop_toBottomOf="@id/bedroom_block">

            <ImageView
                android:id="@+id/ic_kitchen"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/kitchen"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/kitchen_btn"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginEnd="16dp"
                android:autoSizeTextType="uniform"
                android:background="@drawable/roomsbutton"
                android:text="kitchen"
                android:textColor="@color/black"
                android:textSize="18sp"
                app:backgroundTint="@null"
                app:layout_constraintBottom_toBottomOf="@id/ic_kitchen"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ic_kitchen"
                app:layout_constraintTop_toTopOf="@id/ic_kitchen" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- bathroom block -->

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bathroom_block"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/living_block"
            app:layout_constraintEnd_toStartOf="@+id/help4"
            app:layout_constraintStart_toStartOf="@+id/help3"
            app:layout_constraintTop_toBottomOf="@id/kitchen_block">

            <ImageView
                android:id="@+id/ic_bathroom"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bath"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/bathroom_btn"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginEnd="16dp"
                android:autoSizeTextType="uniform"
                android:background="@drawable/roomsbutton"
                android:text="bathroom"
                android:textColor="@color/black"
                android:textSize="18sp"
                app:backgroundTint="@null"
                app:layout_constraintBottom_toBottomOf="@id/ic_bathroom"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ic_bathroom"
                app:layout_constraintTop_toTopOf="@id/ic_bathroom" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- living room block -->

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/living_block"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/help4"
            app:layout_constraintStart_toStartOf="@+id/help3"
            app:layout_constraintTop_toBottomOf="@id/bathroom_block">

            <ImageView
                android:id="@+id/ic_living"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/living_room"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/living_btn"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginEnd="16dp"
                android:autoSizeTextType="uniform"
                android:background="@drawable/roomsbutton"
                android:text="living room"
                android:textColor="@color/black"
                android:textSize="18sp"
                app:backgroundTint="@null"
                app:layout_constraintBottom_toBottomOf="@id/ic_living"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ic_living"
                app:layout_constraintTop_toTopOf="@id/ic_living" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="@id/g_rooms"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/home_btn"
            android:contentDescription="homepage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/homeicon"
            app:backgroundTint="@null"/>

        <ImageView
            android:id="@+id/modifier_id"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="40dp"
            android:background="@drawable/modiericon"/>

        <Button
            android:contentDescription="profilepage"
            android:id="@+id/profile_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/profileicon"
            app:backgroundTint="@null"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
